# Generated by Cargo
# will have compiled files and executables
debug/
target/

# These are intermediate artifacts generated by `rustc`.
# These are only used by the compiler to help speed up incremental builds.
*.d

# Backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which contains some 
# debugging information
*.pdb

# Exclude directories generated by cargo-mutants
**/mutants.out*/

.trash
.clause